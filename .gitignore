# ==========================================
# 1. 全局大文件、压缩包与美术工程源文件过滤
# ==========================================
/**/*.7z
/**/*.zip
/**/*.rar
/**/*.kra
/**/.*.kra
/**/*~

# 全局屏蔽所有 Ren'Py 引擎与游戏生成的脚本编译缓存（彻底解决朋友 pull 不下来的问题）
/**/*.rpyc
/**/*.rpymc
/**/*.rpyb
/renpy/
# ==========================================
# 2. 独立美术资源与本地备份文件夹过滤
# ==========================================
**/rubbish/
**/backup/
**/Game_Assets/

# ==========================================
# 3. Ren'Py 官方默认过滤规则
# ==========================================
# Directories that Ren'Py changes files in.
/game/saves
/game/cache

# Files Ren'Py can generate.
/game/**/*.bak
/game/**/*.new
/game/**/*.old

# Error, log, and output files.
/errors.txt
/files.txt
/image_cache.txt
/log.txt
/save_dump.txt
/traceback.txt

# Launcher-generated files.
/dialogue.tab
/dialogue.txt
/strings.json